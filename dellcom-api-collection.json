{
  "info": {
    "name": "DELLCOM SAC - API Collection",
    "description": "Colección completa de endpoints de la API de DELLCOM SAC. Importar en Postman. Los endpoints administrativos requieren sesión activa: iniciar sesión en el navegador y activar 'Send cookies' en Postman, o configurar la cookie 'next-auth.session-token' como variable de entorno.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "cron_secret", "value": "TU_CRON_SECRET_DEL_ENV", "type": "string" },
    { "key": "licencia_id", "value": "1", "type": "string" },
    { "key": "archivo_id", "value": "1", "type": "string" },
    { "key": "producto_id", "value": "1", "type": "string" },
    { "key": "categoria_id", "value": "1", "type": "string" },
    { "key": "servicio_id", "value": "1", "type": "string" },
    { "key": "trabajo_id", "value": "1", "type": "string" },
    { "key": "mensaje_id", "value": "1", "type": "string" },
    { "key": "usuario_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Endpoints Públicos",
      "item": [
        {
          "name": "GET Productos activos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/productos",
              "host": ["{{base_url}}"],
              "path": ["api", "productos"]
            },
            "description": "Devuelve solo los productos con activo=true."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Respuesta es un array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
                  "pm.test('Cada producto tiene id, nombre y precio', function () {",
                  "  const data = pm.response.json();",
                  "  if (data.length > 0) {",
                  "    pm.expect(data[0]).to.have.all.keys(['id', 'nombre', 'precio']);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET Productos (todos, incluyendo inactivos)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/productos?all=true",
              "host": ["{{base_url}}"],
              "path": ["api", "productos"],
              "query": [{ "key": "all", "value": "true" }]
            },
            "description": "Con ?all=true devuelve también los productos desactivados."
