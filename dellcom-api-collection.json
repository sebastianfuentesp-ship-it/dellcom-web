        {
          "name": "POST Enviar Mensaje de Contacto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Cliente Demo\",\n  \"correo\": \"cliente.demo@gmail.com\",\n  \"telefono\": \"987654321\",\n  \"asunto\": \"Cotización de Servicio\",\n  \"mensaje\": \"Hola, requiero soporte de red en mi local de Los Olivos.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/contacto",
              "host": ["{{base_url}}"],
              "path": ["api", "contacto"]
            },
            "description": "Máximo 5 envíos por IP cada 10 minutos. Devuelve 429 si se supera."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Respuesta tiene success:true', function () {",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('Respuesta contiene el mensaje guardado', function () {",
                  "  pm.expect(pm.response.json().data).to.have.property('id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST Contacto - Validación fallida (nombre corto)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Jo\",\n  \"correo\": \"no-es-correo\",\n  \"asunto\": \"x\",\n  \"mensaje\": \"ok\"\n}"
