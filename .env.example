# =============================================
# DELLCOM SAC - Variables de Entorno
# Copia este archivo como .env y completa los valores
# =============================================

# 1. Base de Datos (MySQL en Railway o local)
DATABASE_URL="mysql://usuario:contrasena@host:puerto/nombre_base_datos"

# 2. NextAuth - Autenticacion
# Genera el secreto con: openssl rand -base64 32
NEXTAUTH_SECRET="escribe_aqui_una_clave_secreta_de_minimo_32_caracteres"
NEXTAUTH_URL="http://localhost:3000"

# 3. AWS S3 - Almacenamiento de archivos (Opcional)
# Si no se configura, los archivos se guardan en /public/uploads/
AWS_ACCESS_KEY_ID="tu_access_key_id_de_iam"
AWS_SECRET_ACCESS_KEY="tu_secret_access_key_de_iam"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="nombre_del_bucket_s3"

# 4. Cron Job - Verificacion automatica de licencias vencidas
# Requerido para que /api/cron/check-licencias funcione
# Genera con: openssl rand -base64 32
CRON_SECRET="clave_aleatoria_segura_para_el_cron"
